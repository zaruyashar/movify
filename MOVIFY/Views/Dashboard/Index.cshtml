@{
    Layout = "~/Views/Shared/_MendyLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="page-breadcrumb">
    <div class="row">
        <div class="col-7 align-self-center">
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="#" class="link">Home</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="card bg-gradient-primary sales-details">
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-4 col-md-6">
                            <div class="d-flex p-3">
                                <div>
                                    <i class="text-white op-7" data-feather="film"></i>
                                    <span class="text-white op-7 d-block my-3">Total Movies</span>
                                    <h3 class="text-white mb-0">@ViewBag.TotalMovies</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="d-flex p-3">
                                <div>
                                    <i class="text-white op-7" data-feather="folder"></i>
                                    <span class="text-white op-7 d-block my-3">Total Categories</span>
                                    <h3 class="text-white mb-0">@ViewBag.TotalCategories</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="d-flex p-3">
                                <div>
                                    <i class="text-white op-7" data-feather="users"></i>
                                    <span class="text-white op-7 d-block my-3">Registered Directors</span>
                                    <h3 class="text-white mb-0">@ViewBag.TotalDirectors</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">

        <!--- TO DO --->
        <div class="col-lg-5 col-md-12">
            <div class="card h-100">
                <div class="card-body border-bottom">
                    <h4 class="card-title">To Do List</h4>
                    <div class="d-flex align-items-center">
                        <div>
                            <!-- Dynamically shows today's date -->
                            <h3 class="text-info font-light mb-0">@DateTime.Now.ToString("d MMMM yyyy")</h3>
                        </div>
                        <div class="ml-auto">
                            <div class="btn-group" role="group">
                                <button type="button" class="btn bg-transparent"><i data-feather="chevron-left"></i></button>
                                <button type="button" class="btn bg-transparent"><i data-feather="chevron-right"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="todo-widget scrollable" style="height:317px;">
                    <ul class="list-task todo-list list-group m-b-0" data-role="tasklist">
                        @foreach (var todo in ViewBag.Todos)
                        {
                            <li class="list-group-item todo-item" data-role="task">
                                <!-- Added d-flex and w-100 to maintain Mendy's spacing with the new form wrappers -->
                                <div class="custom-control custom-checkbox d-flex w-100 align-items-center">

                                    <!-- Checkbox / Toggle Form -->
                                    <form asp-action="ToggleTodo" asp-controller="Dashboard" method="post" class="m-0 p-0 flex-grow-1">
                                        <input type="hidden" name="id" value="@todo.Id" />
                                        <input type="checkbox" class="custom-control-input" id="customCheck_@todo.Id" @(todo.IsCompleted ? "checked" : "") onchange="this.closest('form').submit();">
                                        <label class="custom-control-label todo-label w-100" for="customCheck_@todo.Id">
                                            <span class="todo-desc" style="@(todo.IsCompleted ? "text-decoration: line-through; color: #adb5bd;" : "")">
                                                @todo.Description
                                            </span>
                                        </label>
                                    </form>

                                    <!-- Delete Form (Extracted from the label to prevent accidental check toggles) -->
                                    <form asp-action="DeleteTodo" asp-controller="Dashboard" method="post" class="m-0 p-0 ml-auto">
                                        <input type="hidden" name="id" value="@todo.Id" />
                                        <button type="submit" class="btn p-0 border-0 bg-transparent delete-task">
                                            <i class="text-danger" data-feather="trash-2"></i>
                                        </button>
                                    </form>

                                </div>
                            </li>
                        }
                    </ul>
                </div>

                <div class="card-body">
                    <form asp-action="AddTodo" asp-controller="Dashboard" method="post" class="d-flex align-items-center mt-3">
                        <div class="custom-input w-100">
                            <input type="text" name="description" class="form-control" placeholder="Type Here" required autocomplete="off">
                        </div>
                        <div class="ml-auto">
                            <button type="submit" class="btn bg-transparent border-0 p-2">
                                <i class="text-info" data-feather="plus-circle"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <!--- Chart --->
        <div class="col-lg-7 col-md-12">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div>
                            <h4 class="card-title">Genre Distribution</h4>
                            <h6 class="card-subtitle mb-0">Top categories by movie count</h6>
                        </div>
                    </div>
                    <div class="row align-items-center mt-4">
                        <div class="col-md-7">
                            <div id="category-chart" class="mt-4" style="height:340px;">
                            </div>
                        </div>
                        <div class="col-md-5 ml-auto">
                            <ul class="list-style-none" id="chart-legend">
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        window.addEventListener("load", function() {
        const labels = @Html.Raw(Json.Serialize(ViewBag.CategoryLabels));
        const counts = @Html.Raw(Json.Serialize(ViewBag.CategoryCounts));

        const chartData = [];
        for(let i = 0; i < labels.length; i++) {
            chartData.push([labels[i], counts[i]]);
        }

        const colorPalette = ['#fe7842', '#f352d5', '#b974fe', '#32cdfd', '#5ad84a', '#ffb22b'];
        const colorMap = {};
        labels.forEach((label, index) => {
            colorMap[label] = colorPalette[index % colorPalette.length];
        });

        const legendContainer = document.getElementById('chart-legend');
        labels.forEach((label, index) => {
            const li = document.createElement('li');
            li.className = index === 0 ? '' : 'mt-4';
            li.innerHTML = `<i class="fas fa-circle font-12 mr-2" style="color: ${colorMap[label]}"></i> <span class="text-dark">${label}</span> <span class="text-muted ml-1">${counts[index]}</span>`;
            legendContainer.appendChild(li);
        });

        if (chartData.length > 0) {
            const chartContainer = document.getElementById('category-chart');

            var categoryChart = c3.generate({
                bindto: chartContainer,
                data: {
                    columns: chartData,
                    type: 'donut',
                    colors: colorMap
                },
                donut: {
                    title: "Movies",
                    width: 55,
                    label: { show: false }
                },
                legend: { show: false }
            });

            const resizeObserver = new ResizeObserver(() => {
                categoryChart.resize();
            });

            resizeObserver.observe(chartContainer.parentElement);
        }
    });



</script>