@using MOVIFY.Model
@model IEnumerable<Movie>

@{
    Layout = "~/Views/Shared/_MovifyLayout.cshtml";
    ViewData["Title"] = "Home";
}

<section id="slider" class="full-slider">
    <div class="rev-slider-wrapper fullscreen-container overlay-gradient">
        <div id="fullscreen-slider" class="rev_slider fullscreenbanner" style="display:none" data-version="5.4.1">
            <ul>
                <li data-transition="fade">
                    <img src="/movify-assets/assets/images/slider/slider1.jpg"
                         alt="Welcome to Movify"
                         class="rev-slidebg"
                         data-bgposition="center center"
                         data-bgfit="cover"
                         data-bgrepeat="no-repeat"
                         data-no-retina="">

                    <div class="tp-caption tp-resizeme text-white font-weight-bold text-center"
                         data-x="center"
                         data-y="middle"
                         data-voffset="['-30','-30','-30','-30']"
                         data-fontsize="['60','50','40','30']"
                         style="z-index: 5;">
                        Welcome to Movify
                    </div>

                    <div class="tp-caption tp-resizeme text-white text-center"
                         data-x="center"
                         data-y="middle"
                         data-voffset="['50','50','50','50']"
                         data-fontsize="['20','18','16','14']"
                         style="z-index: 5;">
                        Discover the greatest movies, explore categories, and meet the directors.
                    </div>
                </li>
            </ul>
        </div>
    </div>

    <div class="search-form-wrapper search-form-rev">
        <div class="container">
            <form asp-controller="Default" asp-action="Search" method="get" id="search-form-1">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-sm-10 col-12">
                        <div class="form-group">
                            <input name="keyword" type="text" id="search-keyword" value="" class="form-control" placeholder="Search by Movie, Category or Director..." required>
                            <button type="submit" class="btn btn-main btn-effect"><i class="fa fa-search"></i></button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

<section class="ptb100 bg-light">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-8 text-center">
                <h2 class="title">Latest Additions</h2>
                <h6 class="subtitle">Explore our recently added movies. Handpicked for your entertainment.</h6>
            </div>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var movie in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.3s ease;">
                            <div class="card-body text-center p-4">
                                <div class="mb-4 mt-2">
                                    <i class="fa fa-film fa-3x" style="color: #b974fe;"></i>
                                </div>
                                <h4 class="font-weight-bold mb-1">@movie.MovieTitle</h4>
                                <p class="text-muted mb-3 font-weight-bold">@movie.ReleaseYear</p>

                                <div class="mb-4">
                                    <span class="badge badge-pill text-white px-3 py-2" style="background-color: #32cdfd; font-size: 0.85rem;">
                                        @(movie.Category != null ? movie.Category.CategoryName : "Uncategorized")
                                    </span>
                                </div>

                                <hr style="border-color: rgba(0,0,0,0.05);">
                                <p class="mb-0 text-secondary">
                                    <small class="text-uppercase letter-spacing-1">Directed by</small><br>
                                    <strong class="text-dark">@(movie.Director != null ? movie.Director.DirectorFullName : "Unknown")</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted">No movies have been added to the database yet. Check back soon!</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="blog bg-white ptb100">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center">
                <h2 class="title">Cinema News & Articles</h2>
                <h6 class="subtitle">Catch up with the latest trends and stories from the movie industry.</h6>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="bloglist-post-holder shadow-hover">
                    <a href="#" class="bloglist-thumb-link hover-link">
                        <div class="bloglist-post-thumbnail" style="background: url('/movify-assets/assets/images/blog/bloglist-1.jpg') center center; background-size: cover; height: 250px;"></div>
                    </a>
                    <div class="bloglist-text-wrapper p-4 border border-top-0 rounded-bottom">
                        <h4 class="bloglist-title font-weight-bold mb-2">
                            <a href="#" class="text-dark">Top 10 Action Movies of the Decade</a>
                        </h4>
                        <div class="bloglist-meta text-muted mb-3">
                            <i class="fa fa-calendar mr-1"></i> 27 Jun 2026
                        </div>
                        <div class="bloglist-excerpt">
                            <p class="text-secondary">Explore the most thrilling, explosive, and groundbreaking action films that defined the last ten years of cinema history...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="bloglist-post-holder shadow-hover">
                    <a href="#" class="bloglist-thumb-link hover-link">
                        <div class="bloglist-post-thumbnail" style="background: url('/movify-assets/assets/images/blog/bloglist-2.jpg') center center; background-size: cover; height: 250px;"></div>
                    </a>
                    <div class="bloglist-text-wrapper p-4 border border-top-0 rounded-bottom">
                        <h4 class="bloglist-title font-weight-bold mb-2">
                            <a href="#" class="text-dark">Inside the Director's Mind</a>
                        </h4>
                        <div class="bloglist-meta text-muted mb-3">
                            <i class="fa fa-calendar mr-1"></i> 25 Jun 2026
                        </div>
                        <div class="bloglist-excerpt">
                            <p class="text-secondary">An exclusive interview detailing the creative process, struggles, and triumphs of crafting award-winning masterpieces...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="bloglist-post-holder shadow-hover">
                    <a href="#" class="bloglist-thumb-link hover-link">
                        <div class="bloglist-post-thumbnail" style="background: url('/movify-assets/assets/images/blog/bloglist-3.jpg') center center; background-size: cover; height: 250px;"></div>
                    </a>
                    <div class="bloglist-text-wrapper p-4 border border-top-0 rounded-bottom">
                        <h4 class="bloglist-title font-weight-bold mb-2">
                            <a href="#" class="text-dark">Upcoming Sci-Fi Releases</a>
                        </h4>
                        <div class="bloglist-meta text-muted mb-3">
                            <i class="fa fa-calendar mr-1"></i> 20 Jun 2026
                        </div>
                        <div class="bloglist-excerpt">
                            <p class="text-secondary">Get ready to travel beyond the stars. Here is a sneak peek at the most anticipated science fiction movies coming out soon...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="subscribe bg-light2 ptb100">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 text-center">
                <h2 class="title">Join Movify Now!</h2>
                <h6 class="subtitle">Subscribe to our newsletter to receive the latest updates, movie releases, and exclusive content.</h6>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-7 col-sm-10 col-12">
                <form action="#" class="mailchimp mt50" novalidate>
                    <div class="form-group">
                        <div class="input-group">
                            <input type="email" name="EMAIL" class="form-control" id="mc-email" placeholder="Enter your email address" autocomplete="off">
                            <label for="mc-email"></label>
                            <button type="submit" class="btn btn-main btn-effect">Subscribe</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>