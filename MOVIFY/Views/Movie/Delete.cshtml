@model MOVIFY.Model.Movie

@{
    Layout = "~/Views/Shared/_MendyLayout.cshtml";
    ViewData["Title"] = "Delete Movie";
}

<div class="page-breadcrumb">
    <div class="row align-items-center">
        <div class="col-12 align-self-center">
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent">
                        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="link">Home</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index" class="link">Movies</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Delete Movie</li>
                    </ol>
                </nav>
            </div>
            <h4 class="page-title mt-2 text-danger">Delete Movie</h4>
        </div>
    </div>
</div>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-8 col-md-12">
            <div class="card border-danger">
                <div class="card-body">
                    <h4 class="card-title text-danger"><i class="ti-alert mr-2"></i> Are you sure you want to delete this?</h4>
                    <p class="text-muted mb-4">This action cannot be undone. The movie will be permanently removed from the database.</p>
                    
                    <div class="p-3 bg-light mb-4 rounded">
                        <dl class="row mb-0">
                            <dt class="col-sm-3 font-weight-bold">Movie Title:</dt>
                            <dd class="col-sm-9">@Model.MovieTitle</dd>

                            <dt class="col-sm-3 font-weight-bold">Release Year:</dt>
                            <dd class="col-sm-9">@Model.ReleaseYear</dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="MovieId" />
                        <div class="form-actions mt-4">
                            <button type="submit" class="btn btn-danger px-4 mr-2">Yes, Delete It</button>
                            <a asp-action="Index" class="btn btn-dark px-4">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>