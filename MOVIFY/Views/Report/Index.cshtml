@{
    Layout = "~/Views/Shared/_MendyLayout.cshtml";
    ViewData["Title"] = "Admin Reports";
}

<style>
    .report-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: none;
        border-radius: 12px;
        overflow: hidden;
        color: white;
        text-decoration: none !important;
        display: block;
    }

        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            color: white;
        }

    .grad-primary {
        background: linear-gradient(45deg, #fc4b6c, #8e44ad);
    }

    .grad-info {
        background: linear-gradient(45deg, #1e88e5, #40c4ff);
    }

    .grad-success {
        background: linear-gradient(45deg, #26c6da, #009688);
    }

    .grad-warning {
        background: linear-gradient(45deg, #ffb22b, #ff7043);
    }

    .report-icon {
        font-size: 3.5rem;
        opacity: 0.8;
    }
</style>

<div class="page-breadcrumb">
    <div class="row align-items-center">
        <div class="col-12 align-self-center">
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent">
                        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="link">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Admin Reports</li>
                    </ol>
                </nav>
            </div>
            <h4 class="page-title mt-2">Data Exports</h4>
        </div>
    </div>
</div>


<div class="container-fluid mt-4">
    <div class="row">

        <div class="col-md-6 mb-4">
            <a asp-controller="Report" asp-action="DownloadMoviesReport" class="card report-card grad-primary p-4">
                <div class="d-flex align-items-center">
                    <div class="mr-4">
                        <i class="ti-video-clapper report-icon"></i>
                    </div>
                    <div>
                        <h3 class="font-weight-bold mb-1 text-white">Movies Archive</h3>
                        <span class="text-white-50">Export a complete list of all movies</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 mb-4">
            <a asp-controller="Report" asp-action="DownloadCategoriesReport" class="card report-card grad-info p-4">
                <div class="d-flex align-items-center">
                    <div class="mr-4">
                        <i class="ti-view-list-alt report-icon"></i>
                    </div>
                    <div>
                        <h3 class="font-weight-bold mb-1 text-white">Categories Summary</h3>
                        <span class="text-white-50">Export genre distribution metrics</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 mb-4">
            <a asp-controller="Report" asp-action="DownloadDirectorsReport" class="card report-card grad-success p-4">
                <div class="d-flex align-items-center">
                    <div class="mr-4">
                        <i class="ti-user report-icon"></i>
                    </div>
                    <div>
                        <h3 class="font-weight-bold mb-1 text-white">Directors Master List</h3>
                        <span class="text-white-50">Export the director database</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 mb-4">
            <a asp-controller="Report" asp-action="DownloadAnalyticsReport" class="card report-card grad-warning p-4">
                <div class="d-flex align-items-center">
                    <div class="mr-4">
                        <i class="ti-stats-up report-icon"></i>
                    </div>
                    <div>
                        <h3 class="font-weight-bold mb-1 text-white">System Analytics</h3>
                        <span class="text-white-50">Export user and traffic metrics</span>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>