        <script>
            $('.datepicker').datepicker({
            autoclose: true,
            todayHighlight: true
            });
        </script>

        <!--- Experimenting with hover-only desktop sidebar without a toggle button --->
        <script>
            $(document).ready(function() {
            var wrapper = $("#main-wrapper");
            var sidebar = $(".left-sidebar");

            sidebar.on("mouseenter", function() {
            wrapper.attr("data-sidebartype", "full");
            wrapper.removeClass("mini-sidebar");
            });

            sidebar.on("mouseleave", function() {
            wrapper.attr("data-sidebartype", "mini-sidebar");
            wrapper.addClass("mini-sidebar");
            });
            });
        </script>

        <!--- Searchbox ui improvements: should disappear on Esc hit or background click --->
        <script>
            $(document).ready(function() {
            $(document).keyup(function(e) {
            if (e.key === "Escape" || e.keyCode === 27) {
            $(".srh-btn").click();
            }
            });

            $(document).click(function(e) {
            var container = $(".search-box");

            if (!container.is(e.target) && container.has(e.target).length === 0) {
            if ($(".app-search").is(":visible")) {
            $(".srh-btn").click();
            }
            }
            });
            });
        </script>

        <!--- Mobile sidebar should disappear on background tap --->
        <script>
            $(document).click(function(e) {
            var sidebar = $(".left-sidebar");
            var toggler = $(".nav-toggler");
            var wrapper = $("#main-wrapper");

            if (toggler.is(":visible") && wrapper.hasClass("show-sidebar")) {

            if (!sidebar.is(e.target) && sidebar.has(e.target).length === 0 &&
            !toggler.is(e.target) && toggler.has(e.target).length === 0) {

            wrapper.removeClass("show-sidebar");

            toggler.find("i").removeClass("ti-close").addClass("ti-menu");
            }
            }
            });
        </script>

        <!--- Delete customizations on the Aside panel --->
        <script>
            $(document).ready(function() {
            $("#reset-theme-btn").on("click", function(e) {
            e.preventDefault();
            $('.theme-link[data-logobg="skin2"]').trigger('click');
            $('.theme-link[data-sidebarbg="skin2"]').trigger('click');
            $('.theme-link[data-navbarbg="skin1"]').trigger('click');
            });
            });
        </script>

        <!--- Data tables for CRUD screens --->
