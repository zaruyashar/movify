            .sidebar-nav ul li:first-of-type ~ .nav-small-cap:first-of-type {
                border-top: none !important;
                margin-top: 5px !important;
                padding-top: 10px !important;
            }

            .sidebar-nav ul .list-divider {
                display: none !important;
            }
